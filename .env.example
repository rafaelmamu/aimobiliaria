# ===========================================
# AImobiliarIA — Environment Variables
# ===========================================
# Copie este arquivo para .env e preencha os valores

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=CHANGE-ME-generate-a-strong-random-key

# Database (PostgreSQL)
POSTGRES_USER=aimobiliaria
POSTGRES_PASSWORD=CHANGE-ME-strong-password
POSTGRES_DB=aimobiliaria
DATABASE_URL=postgresql+asyncpg://aimobiliaria:CHANGE-ME-strong-password@db:5432/aimobiliaria

# Redis
REDIS_URL=redis://redis:6379/0

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-CHANGE-ME

# Meta WhatsApp Cloud API
META_WHATSAPP_VERIFY_TOKEN=aimobiliaria-verify-2026

# Logging
LOG_LEVEL=INFO

# CRM49 sync (external property API)
CRM49_SYNC_ENABLED=true
CRM49_SYNC_INTERVAL_MINUTES=30
CRM49_DETAILS_CACHE_TTL_SECONDS=900
